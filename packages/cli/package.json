{
  "name": "@elisym/husk",
  "version": "0.2.0",
  "description": "HUSK CLI - serve a folder of agent skills over HTTP with one Bun process. Scaffold, list, call, and containerize skills.",
  "keywords": [
    "agent-skills",
    "bun",
    "cli",
    "elisymlabs",
    "http",
    "husk",
    "skills"
  ],
  "homepage": "https://github.com/igorperegudov/husk",
  "bugs": {
    "url": "https://github.com/igorperegudov/husk/issues"
  },
  "license": "MIT",
  "author": "elisym labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/igorperegudov/husk.git",
    "directory": "packages/cli"
  },
  "bin": {
    "husk": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "lint": "oxlint src/",
    "qa": "tsup && vitest run && tsc --noEmit && oxlint src/ && oxfmt --check src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "~5.6.0",
    "commander": "~13.1.0"
  },
  "devDependencies": {
    "@elisym/husk-core": "workspace:*",
    "@types/bun": "~1.3.0",
    "@types/node": "~22.0.0",
    "tsup": "~8.4.0",
    "typescript": "~5.7.0",
    "vitest": "~3.0.0"
  },
  "engines": {
    "bun": ">=1.1"
  }
}
