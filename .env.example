# HUSK reads provider API keys (for `mode: llm` skills and proxy `${VAR}` headers)
# from the environment. Bun auto-loads this file when you run `husk serve` from
# this directory - just copy it to `.env` and fill in the keys you need:
#
#   cp .env.example .env
#
# `.env` is gitignored; never commit real keys.

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=

# Optional: override the default port for `husk serve`.
# HUSK_PORT=3000
