{
  "name": "husk",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint packages/core/src/ packages/cli/src/",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "spell": "cspell --no-progress \"packages/*/src/**\" \"*.md\" \"packages/*/README.md\"",
    "qa": "turbo run build && turbo run test && turbo run typecheck && bun run lint && oxfmt --check . && bun run spell",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "cspell": "~9.0.0",
    "oxfmt": "~0.42.0",
    "oxlint": "~0.16.0",
    "turbo": "~2.4.0",
    "typescript": "~5.7.0"
  },
  "packageManager": "bun@1.3.11"
}
